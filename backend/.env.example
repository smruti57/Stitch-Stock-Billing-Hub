# ── Copy to .env and fill in your values ───────────────────────
# cp .env.example .env

# Server
PORT=5000
NODE_ENV=development

# MongoDB  (Docker service name is "mongo")
MONGO_URI=mongodb://mongo:27017/shopflow

# JWT — change this to a long random string in production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme_replace_with_64char_random_string
JWT_EXPIRES_IN=24h

# GST (India)
GST_RATE=0.18
